# Copie este arquivo para `.env` e preencha os valores.

PORT=5001
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# IA (Groq)
GROQ_API_KEY=seu_token_aqui

# Auth (JWT)
JWT_SECRET=troque_por_um_segredo_longo

# Administradores (emails separados por vírgula) — podem criar/editar períodos e lições via API
# ADMIN_EMAILS=voce@exemplo.com

# Opcional: marcar is_admin no banco (UPDATE users SET is_admin = TRUE WHERE email = '...')
